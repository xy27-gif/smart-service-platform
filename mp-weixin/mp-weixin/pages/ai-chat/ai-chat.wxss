/* 页面整体样式 */
.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  height: 100rpx;
  background: #ffc200;
  padding: 0 30rpx 20rpx;
  box-sizing: border-box;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10rpx;
}

.nav-right {
  width: 60rpx;
}

/* 白色区域顶部的返回键 */
.chat-container {
  flex: 1;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
  position: relative;
}

.chat-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: #fff;
  z-index: 1;
}

.back-button {
  position: absolute;
  top: 20rpx;
  left: 30rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  z-index: 2;
}

.back-button-icon {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
}

/* 聊天容器 */
.chat-container {
  flex: 1;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

/* 欢迎区域 */
.welcome-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.ai-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(255, 194, 0, 0.3);
  margin-bottom: 30rpx;
}

.welcome-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.welcome-subtext {
  font-size: 28rpx;
  color: #999;
}

/* 消息列表 */
.message-list {
  display: flex;
  flex-direction: column;
}

.message-wrapper {
  margin-bottom: 30rpx;
}

/* 消息行 */
.message-row {
  display: flex;
  align-items: flex-start;
}

.ai-row {
  justify-content: flex-start;
}

.user-row {
  justify-content: flex-end;
}

/* 头像 */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.ai-avatar-small {
  background: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  background: linear-gradient(135deg, #ffc200 0%, #ff9500 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

/* 消息内容 */
.message-content {
  max-width: 70%;
  margin: 0 20rpx;
}

.ai-content {
  align-items: flex-start;
}

.user-content {
  align-items: flex-end;
}

/* 消息气泡 */
.message-bubble {
  padding: 24rpx 30rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-wrap: break-word;
  position: relative;
}

.ai-bubble {
  background: #fff;
  color: #333;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  border-top-left-radius: 8rpx;
}

.user-bubble {
  background: linear-gradient(135deg, #ffc200 0%, #ff9500 100%);
  color: #fff;
  border-top-right-radius: 8rpx;
}

.message-text {
  display: inline;
}

/* 流式指示器 */
.streaming-indicator {
  display: inline-flex;
  align-items: center;
  margin-left: 10rpx;
  gap: 6rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  background: #999;
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite;
}

.dot:nth-child(1) {
  animation-delay: 0s;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-10rpx);
  }
}

/* 消息时间 */
.message-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 10rpx;
}

/* 系统消息 */
.system-message {
  display: flex;
  justify-content: center;
  margin: 20rpx 0;
}

.system-text {
  font-size: 24rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.05);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

/* 快捷问题 */
.quick-questions {
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.quick-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-item {
  background: #f5f5f5;
  color: #666;
  font-size: 26rpx;
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  transition: all 0.3s;
}

.quick-item:active {
  background: #ffc200;
  color: #fff;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.input-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 24rpx;
  margin-right: 20rpx;
}

.message-input {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  color: #333;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

/* 发送按钮 */
.send-btn {
  width: 120rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e0e0e0;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
  padding: 0;
  transition: all 0.3s;
}

.send-btn.active {
  background: linear-gradient(135deg, #ffc200 0%, #ff9500 100%);
}

.send-btn[disabled] {
  opacity: 0.6;
}

/* 加载动画 */
.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}
